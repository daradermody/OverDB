{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "ESNext",
    "sourceMap": false,
    "lib": ["ESNext"],
    "strict": true,
    "types": ["bun-types"],
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "noEmit": true
  }
}
